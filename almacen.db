CREATE TABLE Inventario_Equipos (
    id INTEGER PRIMARY KEY AUTOINCREMENT,        
    tipo TEXT CHECK(tipo IN ('Portatil', 'Cascos', 'Monitor')), 
    modelo VARCHAR(100) NOT NULL,               
    numero_serie VARCHAR(50) DEFAULT NULL       
);


